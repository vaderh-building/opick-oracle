{
  "name": "opick-oracle",
  "version": "2.0.0",
  "description": "OPick Oracle: V6 market oracle and engagement metric provider",
  "main": "dist/src/server/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server/index.ts",
    "build": "tsc && mkdir -p dist/src/oracle/abi && cp src/oracle/abi/*.json dist/src/oracle/abi/",
    "start": "node dist/src/server/index.js",
    "validate": "ts-node scripts/validate.ts",
    "test:metrics": "ts-node scripts/testMetrics.ts",
    "test:settlement:dry-run": "ts-node scripts/settlementDryRun.ts",
    "verify-audit": "ts-node scripts/verifyAuditLog.ts"
  },
  "dependencies": {
    "@noble/hashes": "^2.2.0",
    "axios": "^1.7.0",
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "node-cron": "^3.0.3",
    "viem": "^2.48.4",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.0",
    "@types/node-cron": "^3.0.11",
    "@types/ws": "^8.5.10",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0"
  }
}
